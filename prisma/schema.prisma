generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  loginId       String         @unique @db.VarChar(20)
  passwordHash  String
  nickname      String         @unique @db.VarChar(10)
  point         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  focusSessions FocusSession[]
  habitRecords  HabitRecord[]
  studyMembers  StudyMember[]

  @@index([point])
}

model Study {
  id              String         @id @default(uuid())
  nickname        String         @db.VarChar(30)
  name            String         @db.VarChar(50)
  description     String         @db.VarChar(200)
  backgroundType  String         @db.VarChar(20)
  backgroundValue String
  point           Int            @default(0)
  maxMembers      Int            @default(3)
  isRecruiting    Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
  focusSessions   FocusSession[]
  habits          Habit[]
  emojis          StudyEmoji[]
  studyMembers    StudyMember[]

  @@index([createdAt])
  @@index([point])
  @@index([deletedAt])
  @@index([name])
  @@index([isRecruiting])
}

model StudyMember {
  id       String          @id @default(uuid())
  userId   String
  studyId  String
  role     StudyMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())
  study    Study           @relation(fields: [studyId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, studyId])
  @@index([userId])
  @@index([studyId])
  @@index([studyId, role])
}

model StudyEmoji {
  id        String   @id @default(uuid())
  studyId   String
  emoji     String   @db.VarChar(20)
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  study     Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([studyId, emoji])
  @@index([studyId])
}

model Habit {
  id           String        @id @default(uuid())
  studyId      String
  name         String
  habitStatus  HabitStatus   @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  study        Study         @relation(fields: [studyId], references: [id], onDelete: Cascade)
  habitRecords HabitRecord[]

  @@index([studyId])
}

model HabitRecord {
  id         String   @id @default(uuid())
  habitId    String
  userId     String
  recordDate DateTime
  isChecked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  habit      Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, userId, recordDate])
  @@index([userId])
  @@index([habitId])
}

model FocusSession {
  id              String   @id @default(uuid())
  userId          String
  studyId         String
  durationSeconds Int
  startedAt       DateTime
  point           Int      @default(0)
  createdAt       DateTime @default(now())
  study           Study    @relation(fields: [studyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@index([studyId])
}

enum StudyMemberRole {
  HOST
  MEMBER
}

enum HabitStatus {
  ACTIVE
  INACTIVE
}
