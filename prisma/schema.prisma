generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum StudyMemberRole {
  HOST
  MEMBER
}

enum HabitStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String   @id @default(uuid())
  loginId      String   @unique @db.VarChar(20)
  passwordHash String
  nickname     String   @unique @db.VarChar(10)
  point        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studyMembers  StudyMember[]
  focusSessions FocusSession[]
  habitRecords  HabitRecord[]

  // ✅ 추가: 유저가 즐겨찾기한 스터디 목록
  studyFavorites StudyFavorite[]

  @@index([point])
}

model Study {
  id              String    @id @default(uuid())
  // 생성 당시 HOST 사용자 닉네임 스냅샷
  nickname        String    @db.VarChar(30)
  name            String    @db.VarChar(50)
  description     String    @db.VarChar(200)
  backgroundType  String    @db.VarChar(20)
  backgroundValue String
  point           Int       @default(0)
  maxMembers      Int       @default(3) // HOST 포함 최대 참여 인원
  isRecruiting    Boolean   @default(true) // true: 모집 중, false: 모집 마감
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  habits        Habit[]
  emojis        StudyEmoji[]
  studyMembers  StudyMember[]
  focusSessions FocusSession[]

  // ✅ 추가: 이 스터디를 즐겨찾기한 내역들
  studyFavorites StudyFavorite[]

  @@index([createdAt])
  @@index([point])
  @@index([deletedAt])
  @@index([name])
  @@index([isRecruiting])
}

// ✅ 신규 모델 추가: 스터디 즐겨찾기
model StudyFavorite {
  id        String   @id @default(uuid())
  userId    String
  studyId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)

  // 한 유저가 같은 스터디를 여러 번 즐겨찾기 할 수 없도록 고유키 설정
  @@unique([userId, studyId])
  // 빠른 조회를 위한 인덱스 설정
  @@index([userId])
  @@index([studyId])
}

model StudyMember {
  id       String          @id @default(uuid())
  userId   String
  studyId  String
  role     StudyMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  study Study @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@unique([userId, studyId])
  @@index([userId])
  @@index([studyId])
  @@index([studyId, role])
}

model StudyEmoji {
  id      String @id @default(uuid())
  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  emoji String @db.VarChar(20)
  count Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studyId, emoji])
  @@index([studyId])
}

model Habit {
  id      String @id @default(uuid())
  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  name        String
  habitStatus HabitStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  habitRecords HabitRecord[]

  @@index([studyId])
}

model HabitRecord {
  id      String @id @default(uuid())
  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  recordDate DateTime
  isChecked  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([habitId, userId, recordDate])
  @@index([userId])
  @@index([habitId])
}

model FocusSession {
  id      String @id @default(uuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyId String
  study   Study  @relation(fields: [studyId], references: [id], onDelete: Cascade)

  durationSeconds Int
  startedAt       DateTime
  point           Int      @default(0)

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([studyId])
}
